<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <title>📘 Capítulo 3: GraphSAGE - Explicación Detallada</title>
  <!-- KaTeX para renderizar ecuaciones LaTeX -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"
    onload="renderMathInElement(document.body, {delimiters: [{left: '$$', right: '$$', display: true},{left: '$', right: '$', display: false}]});"></script>
  <style>
    :root {
      --primary: #059669;
      --primary-dark: #047857;
      --secondary: #6366f1;
      --success: #10b981;
      --warning: #f59e0b;
      --danger: #ef4444;
      --text: #1e293b;
      --text-light: #64748b;
      --bg: #f8fafc;
      --sage-green: #059669;
      --sage-light: #d1fae5;
      --gcn-blue: #3b82f6;
      --gat-pink: #e11d48;
      --sage-emerald: #10b981;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: 'Segoe UI', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.8;
      font-size: 17px;
    }

    /* HERO */
    .hero {
      background: linear-gradient(135deg, #059669 0%, #6366f1 50%, #8b5cf6 100%);
      color: white;
      padding: 80px 24px;
      text-align: center;
    }

    .hero h1 {
      font-size: 2.8rem;
      margin: 0 0 15px;
      font-weight: 300;
    }

    .hero h1 strong { font-weight: 700; color: #fbbf24; }

    .hero p {
      font-size: 1.2rem;
      opacity: 0.95;
      max-width: 750px;
      margin: 0 auto;
    }

    .hero-badge {
      display: inline-block;
      background: #fbbf24;
      color: #000;
      padding: 10px 25px;
      border-radius: 25px;
      font-weight: 700;
      margin-top: 25px;
    }

    /* MAIN */
    main {
      max-width: 1000px;
      margin: 0 auto;
      padding: 50px 24px;
    }

    /* SECTION */
    .section {
      background: white;
      border-radius: 20px;
      padding: 40px;
      margin-bottom: 30px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.06);
      border: 1px solid #e5e7eb;
    }

    .section-header {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 30px;
      padding-bottom: 20px;
      border-bottom: 2px solid #e5e7eb;
    }

    .section-number {
      width: 60px;
      height: 60px;
      background: linear-gradient(135deg, #059669 0%, #6366f1 100%);
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      font-weight: 700;
      flex-shrink: 0;
    }

    .section-title h2 {
      margin: 0;
      color: var(--primary-dark);
      font-size: 1.6rem;
    }

    .section-title p {
      margin: 5px 0 0;
      color: var(--text-light);
      font-size: 0.95rem;
    }

    /* CODE BLOCK */
    .code-block {
      background: #1e293b;
      border-radius: 12px;
      padding: 20px 25px;
      margin: 20px 0;
      overflow-x: auto;
    }

    .code-block pre {
      margin: 0;
      color: #e2e8f0;
      font-family: 'Consolas', 'Monaco', monospace;
      font-size: 0.9rem;
      line-height: 1.6;
    }

    .code-block .comment { color: #6b7280; }
    .code-block .keyword { color: #c084fc; }
    .code-block .function { color: #60a5fa; }
    .code-block .string { color: #34d399; }
    .code-block .number { color: #fbbf24; }

    /* EXPLANATION BOX */
    .explain-box {
      background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
      border-radius: 16px;
      padding: 25px 30px;
      margin: 25px 0;
      border-left: 5px solid var(--primary);
    }

    .explain-box h4 {
      margin: 0 0 10px;
      color: #065f46;
      font-size: 1.1rem;
    }

    .explain-box p {
      margin: 0;
      color: #064e3b;
    }

    /* WARNING BOX */
    .warning-box {
      background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
      border-radius: 16px;
      padding: 25px 30px;
      margin: 25px 0;
      border-left: 5px solid var(--warning);
    }

    .warning-box h4 {
      margin: 0 0 10px;
      color: #92400e;
    }

    .warning-box p {
      margin: 0;
      color: #78350f;
    }

    /* SUCCESS BOX */
    .success-box {
      background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%);
      border-radius: 16px;
      padding: 25px 30px;
      margin: 25px 0;
      border-left: 5px solid var(--success);
    }

    .success-box h4 {
      margin: 0 0 10px;
      color: #047857;
    }

    .success-box p {
      margin: 0;
      color: #166534;
    }

    /* DANGER BOX */
    .danger-box {
      background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
      border-radius: 16px;
      padding: 25px 30px;
      margin: 25px 0;
      border-left: 5px solid var(--danger);
    }

    .danger-box h4 {
      margin: 0 0 10px;
      color: #991b1b;
    }

    .danger-box p {
      margin: 0;
      color: #7f1d1d;
    }

    /* VISUAL DIAGRAM */
    .diagram {
      background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
      border-radius: 16px;
      padding: 30px;
      margin: 25px 0;
      text-align: center;
    }

    .diagram svg {
      max-width: 100%;
      height: auto;
    }

    .diagram .caption {
      margin-top: 15px;
      font-size: 0.9rem;
      color: var(--text-light);
      font-style: italic;
    }

    /* FLOW STEPS */
    .flow-steps {
      display: flex;
      gap: 15px;
      margin: 25px 0;
      flex-wrap: wrap;
    }

    .flow-step {
      flex: 1;
      min-width: 200px;
      background: white;
      border: 2px solid #e5e7eb;
      border-radius: 12px;
      padding: 20px;
      text-align: center;
      position: relative;
    }

    .flow-step::after {
      content: '→';
      position: absolute;
      right: -20px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 1.5rem;
      color: var(--primary);
    }

    .flow-step:last-child::after {
      display: none;
    }

    .flow-step .icon {
      font-size: 2rem;
      margin-bottom: 10px;
    }

    .flow-step h5 {
      margin: 0 0 5px;
      color: var(--primary-dark);
    }

    .flow-step p {
      margin: 0;
      font-size: 0.85rem;
      color: var(--text-light);
    }

    /* OUTPUT BOX */
    .output-box {
      background: #f1f5f9;
      border: 1px solid #cbd5e1;
      border-radius: 10px;
      padding: 15px 20px;
      margin: 15px 0;
      font-family: monospace;
      font-size: 0.85rem;
      color: #475569;
    }

    .output-box .label {
      font-weight: 600;
      color: var(--primary);
      margin-bottom: 8px;
      font-family: 'Segoe UI', sans-serif;
    }

    /* TABLE */
    .data-table {
      width: 100%;
      border-collapse: collapse;
      margin: 20px 0;
    }

    .data-table th, .data-table td {
      padding: 12px 15px;
      text-align: left;
      border-bottom: 1px solid #e5e7eb;
    }

    .data-table th {
      background: linear-gradient(135deg, #059669, #6366f1);
      color: white;
      font-weight: 600;
    }

    .data-table tr:hover {
      background: #f8fafc;
    }

    /* ARCHITECTURE */
    .architecture {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 20px;
      margin: 30px 0;
      flex-wrap: wrap;
    }

    .arch-block {
      background: linear-gradient(135deg, #059669 0%, #6366f1 100%);
      color: white;
      padding: 25px 30px;
      border-radius: 15px;
      text-align: center;
      min-width: 150px;
    }

    .arch-block h5 {
      margin: 0 0 5px;
      font-size: 1.1rem;
    }

    .arch-block p {
      margin: 0;
      font-size: 0.85rem;
      opacity: 0.9;
    }

    .arch-arrow {
      font-size: 2rem;
      color: var(--primary);
    }

    /* HIGHLIGHT QUOTE */
    .highlight {
      background: linear-gradient(135deg, #059669 0%, #6366f1 100%);
      color: white;
      padding: 35px;
      border-radius: 16px;
      text-align: center;
      margin: 30px 0;
    }

    .highlight .icon { font-size: 2.5rem; margin-bottom: 15px; }
    .highlight p { font-size: 1.2rem; margin: 0; }
    .highlight strong { color: #fbbf24; }

    /* GRID */
    .grid-2 {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 20px;
      margin: 25px 0;
    }

    .grid-item {
      background: white;
      border: 2px solid #e5e7eb;
      border-radius: 12px;
      padding: 25px;
    }

    .grid-item h4 {
      margin: 0 0 10px;
      color: var(--primary-dark);
    }

    /* DEEP DIVE SECTION */
    .deep-dive {
      background: linear-gradient(135deg, #064e3b 0%, #1e1b4b 100%);
      border-radius: 20px;
      padding: 40px;
      margin: 30px 0;
      color: white;
    }

    .deep-dive h3 {
      color: #fbbf24;
      margin-top: 0;
    }

    .deep-dive-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
      margin-top: 25px;
    }

    .deep-dive-card {
      background: rgba(255,255,255,0.1);
      border-radius: 15px;
      padding: 25px;
      border: 1px solid rgba(255,255,255,0.2);
    }

    .deep-dive-card h4 {
      color: #fbbf24;
      margin: 0 0 15px;
      font-size: 1.1rem;
    }

    .deep-dive-card p {
      color: rgba(255,255,255,0.9);
      margin: 0;
      line-height: 1.7;
    }

    /* FORMULA BOX */
    .formula-box {
      background: #1e293b;
      border-radius: 12px;
      padding: 20px;
      margin: 20px 0;
      text-align: center;
      font-family: 'Georgia', serif;
    }

    .formula-box .formula {
      font-size: 1.3rem;
      color: #fbbf24;
      margin: 10px 0;
    }

    .formula-box .description {
      font-size: 0.9rem;
      color: #94a3b8;
      font-family: 'Segoe UI', sans-serif;
    }

    /* COMPARISON */
    .comparison-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 15px;
      margin: 25px 0;
    }

    .comparison-card {
      border-radius: 16px;
      padding: 25px;
      border: 3px solid;
    }

    .comparison-card.gcn {
      background: linear-gradient(135deg, #dbeafe 0%, #eff6ff 100%);
      border-color: #3b82f6;
    }

    .comparison-card.gat {
      background: linear-gradient(135deg, #fce7f3 0%, #fdf2f8 100%);
      border-color: #e11d48;
    }

    .comparison-card.sage {
      background: linear-gradient(135deg, #d1fae5 0%, #ecfdf5 100%);
      border-color: #059669;
    }

    .comparison-card h4 {
      margin: 0 0 15px;
    }

    /* LAYER CARD */
    .layer-card {
      background: white;
      border-radius: 16px;
      padding: 30px;
      margin: 20px 0;
      border: 2px solid #e5e7eb;
      position: relative;
      overflow: hidden;
    }

    .layer-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 6px;
      height: 100%;
      background: var(--layer-color, var(--primary));
    }

    .layer-card h4 {
      color: var(--layer-color, var(--primary));
      margin: 0 0 15px;
      font-size: 1.3rem;
    }

    .layer-card .dimensions {
      display: inline-block;
      background: var(--layer-color, var(--primary));
      color: white;
      padding: 5px 15px;
      border-radius: 20px;
      font-size: 0.9rem;
      margin-bottom: 15px;
    }

    /* FOOTER */
    footer {
      background: #1e293b;
      color: white;
      text-align: center;
      padding: 40px 24px;
      margin-top: 50px;
    }

    footer a {
      color: #fbbf24;
      text-decoration: none;
    }

    /* ANIMATIONS */
    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.1); opacity: 0.8; }
    }

    @keyframes flowRight {
      0% { transform: translateX(0); opacity: 1; }
      50% { transform: translateX(10px); opacity: 0.5; }
      100% { transform: translateX(0); opacity: 1; }
    }

    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes samplePulse {
      0%, 100% { r: 14; opacity: 1; }
      50% { r: 17; opacity: 0.7; }
    }

    @keyframes edgeFlow {
      0% { stroke-dashoffset: 0; }
      100% { stroke-dashoffset: -20; }
    }

    .animate-pulse { animation: pulse 2s infinite; }
    .animate-flow { animation: flowRight 1.5s infinite; }
    .hero-sample-node { animation: samplePulse 2s ease-in-out infinite; }
    .hero-edge-animated {
      stroke-dasharray: 8, 4;
      animation: edgeFlow 1.5s linear infinite;
    }

    /* SCROLL REVEAL */
    .section {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }
    .section.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* HOVER EFFECTS */
    .comparison-card {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .comparison-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 30px rgba(0,0,0,0.12);
    }

    .flow-step {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .flow-step:hover {
      transform: translateY(-4px);
      box-shadow: 0 6px 20px rgba(0,0,0,0.1);
    }

    .grid-item {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .grid-item:hover {
      transform: translateY(-3px);
      box-shadow: 0 6px 20px rgba(0,0,0,0.08);
    }

    .deep-dive-card {
      transition: transform 0.3s ease, background 0.3s ease;
    }
    .deep-dive-card:hover {
      transform: translateY(-4px);
      background: rgba(255,255,255,0.18);
    }

    .arch-block {
      transition: transform 0.3s ease;
    }
    .arch-block:hover {
      transform: scale(1.05);
    }

    .layer-card {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .layer-card:hover {
      transform: translateX(5px);
      box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    }

    /* ═══════════ SIDEBAR NAV ═══════════ */
    .sidebar-nav {
      position: fixed;
      top: 0;
      left: 0;
      width: 260px;
      height: 100vh;
      background: linear-gradient(180deg, #064e3b 0%, #1e1b4b 100%);
      overflow-y: auto;
      z-index: 1000;
      padding: 20px 0;
      transform: translateX(0);
      transition: transform 0.3s ease;
      scrollbar-width: thin;
      scrollbar-color: rgba(255,255,255,0.2) transparent;
    }

    .sidebar-nav::-webkit-scrollbar { width: 5px; }
    .sidebar-nav::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 5px; }

    .sidebar-nav .sidebar-title {
      color: #fbbf24;
      font-size: 0.85rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      padding: 10px 20px 15px;
      margin: 0;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .sidebar-nav a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 20px;
      color: rgba(255,255,255,0.7);
      text-decoration: none;
      font-size: 0.85rem;
      transition: all 0.2s ease;
      border-left: 3px solid transparent;
      line-height: 1.4;
    }

    .sidebar-nav a:hover {
      background: rgba(255,255,255,0.08);
      color: white;
      border-left-color: rgba(255,255,255,0.3);
    }

    .sidebar-nav a.active {
      background: rgba(255,255,255,0.12);
      color: #fbbf24;
      border-left-color: #fbbf24;
      font-weight: 600;
    }

    .sidebar-nav a .nav-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: rgba(255,255,255,0.1);
      font-size: 0.75rem;
      font-weight: 700;
      flex-shrink: 0;
    }

    .sidebar-nav a.active .nav-badge {
      background: #fbbf24;
      color: #1e293b;
    }

    .sidebar-nav .nav-divider {
      height: 1px;
      background: rgba(255,255,255,0.08);
      margin: 8px 20px;
    }

    /* Toggle button */
    .sidebar-toggle {
      position: fixed;
      top: 15px;
      left: 15px;
      z-index: 1001;
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: linear-gradient(135deg, #059669, #6366f1);
      color: white;
      border: 2px solid white;
      cursor: pointer;
      display: flex;
      transition: left 0.3s ease;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      box-shadow: 0 2px 12px rgba(0,0,0,0.3);
      transition: all 0.3s ease;
    }

    .sidebar-toggle:hover {
      transform: scale(1.1);
      box-shadow: 0 4px 20px rgba(0,0,0,0.4);
    }

    /* Move toggle when sidebar is open */
    body.sidebar-open .sidebar-toggle {
      left: 270px;
    }

    /* Shift content when sidebar is open */
    body.sidebar-open .hero,
    body.sidebar-open main,
    body.sidebar-open footer,
    body.sidebar-open > div:first-child {
      margin-left: 260px;
      transition: margin-left 0.3s ease;
    }

    body .hero,
    body main,
    body footer,
    body > div:first-child {
      transition: margin-left 0.3s ease;
    }

    /* Collapsed state */
    body:not(.sidebar-open) .sidebar-nav {
      transform: translateX(-260px);
    }

    /* Progress indicator at top of sidebar */
    .sidebar-progress {
      padding: 10px 20px 5px;
    }

    .sidebar-progress-bar {
      width: 100%;
      height: 4px;
      background: rgba(255,255,255,0.1);
      border-radius: 2px;
      overflow: hidden;
    }

    .sidebar-progress-fill {
      height: 100%;
      background: linear-gradient(90deg, #059669, #fbbf24);
      border-radius: 2px;
      width: 0%;
      transition: width 0.3s ease;
    }

    .sidebar-progress-text {
      color: rgba(255,255,255,0.5);
      font-size: 0.7rem;
      margin-top: 4px;
      text-align: right;
    }

    @media (max-width: 768px) {
      .hero h1 { font-size: 2rem; }
      .comparison-grid { grid-template-columns: 1fr; }
      .flow-steps { flex-direction: column; }
      .flow-step::after { display: none; }
      .section { opacity: 1; transform: none; }

      .sidebar-nav { width: 240px; }
      body.sidebar-open .hero,
      body.sidebar-open main,
      body.sidebar-open footer,
      body.sidebar-open > div:first-child {
        margin-left: 0;
      }
      /* overlay backdrop on mobile */
      .sidebar-backdrop {
        display: none;
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.5);
        z-index: 999;
      }
      body.sidebar-open .sidebar-backdrop { display: block; }
    }
  </style>
</head>
<body class="sidebar-open">

<!-- ═══════════ SIDEBAR NAVIGATION ═══════════ -->
<button class="sidebar-toggle" onclick="toggleSidebar()" title="Menú de navegación">☰</button>
<div class="sidebar-backdrop" onclick="toggleSidebar()"></div>

<nav class="sidebar-nav" id="sidebarNav">
  <div class="sidebar-title">📘 Cap 3 · GraphSAGE</div>
  <div class="sidebar-progress">
    <div class="sidebar-progress-bar"><div class="sidebar-progress-fill" id="progressFill"></div></div>
    <div class="sidebar-progress-text" id="progressText">0%</div>
  </div>
  <div class="nav-divider"></div>
  <a href="#hero" class="active"><span class="nav-badge">🏠</span> Inicio</a>
  <a href="#sec-instrucciones"><span class="nav-badge">📋</span> Cómo usar esta guía</a>
  <div class="nav-divider"></div>
  <a href="#sec-0"><span class="nav-badge">0</span> La Gran Idea</a>
  <a href="#sec-1"><span class="nav-badge">1</span> Instalación</a>
  <a href="#sec-2"><span class="nav-badge">2</span> Dataset PubMed</a>
  <a href="#sec-3"><span class="nav-badge">3</span> Mini-Batching</a>
  <a href="#sec-4"><span class="nav-badge">4</span> Distrib. de grados</a>
  <a href="#sec-5"><span class="nav-badge">5</span> Implementación</a>
  <a href="#sec-5b"><span class="nav-badge">5½</span> Los 3 agregadores</a>
  <div class="nav-divider"></div>
  <a href="#sec-6"><span class="nav-badge">6</span> Entrenar GraphSAGE</a>
  <a href="#sec-7"><span class="nav-badge">7</span> Entrenar GCN</a>
  <a href="#sec-8"><span class="nav-badge">8</span> Entrenar GAT</a>
  <a href="#sec-9"><span class="nav-badge">9</span> Comparación final</a>
